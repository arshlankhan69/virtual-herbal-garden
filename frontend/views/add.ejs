
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ask a Question – Virtual Herbal Garden</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="stylesheet" href="/add.css">

</head>

<body>

    <header>
        <div class="header-content">
            <div class="logo">
                <i class="fa-solid fa-leaf"></i>
                <h2>Virtual Herbal Garden</h2>
            </div>
            <nav>
                <ul class="nav-links">
                    <li><a href="/home/new">Home</a></li>
                    <li><a href="/store/new">Store</a></li>
                    <li><a href="/forum/new">Forum</a></li>
                </ul>

                <i class="fas fa-bars" id="hamburger"></i>
                <i class="fas fa-times" id="close-icon"></i>
            </nav>
        </div>
    </header>

    <section class="ask-hero">
        <h1>Ask Your Herbal Question 🌿</h1>
        <p>Share doubts • Get help • Learn together</p>
    </section>


    <form class="ask-form" method="post" action="/forum/add">
        <label for="title">Title:</label><br>
        <input type="text" id="title" name="title"><br><br>

        <label for="author">Enter your name</label><br>
        <input type="text" id="author" name="author"><br><br>
        <label for="tags">Tags (comma separated):</label><br>
        <input type="text" id="tags" name="tags"><br><br>
        <label for="content">Question:</label><br>
        <textarea id="content" name="content" rows="4" cols="50"></textarea><br><br>
        <button type="submit" class="ask-query-btn">Ask your query</button>
    </form>

    <footer>
        <div class="footer-container">
            <div class="footer-left">
                <h3>Virtual Herbal Garden</h3>
                <p>Your trusted source for herbal knowledge and wellness.</p>
            </div>

            <div class="footer-center">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="index.html">Home</a></li>
                    <li><a href="indexsStore.html">Store</a></li>
                    <li><a href="#">Forum</a></li>
                </ul>
            </div>

            <div class="footer-right">
                <h4>Contact</h4>
                <p><i class="fas fa-envelope"></i> herbalgaarden@gmail.com</p>
                <p><i class="fas fa-phone"></i> +91 9792622196</p>
            </div>
        </div>

        <div class="footer-bottom">
            <p>© 2025 Virtual Herbal Garden. All Rights Reserved.</p>
        </div>
    </footer>

    <script>
        /* MOBILE MENU SCRIPT */
        const hamburger = document.getElementById("hamburger");
        const closeIcon = document.getElementById("close-icon");
        const navLinks = document.querySelector(".nav-links");

        hamburger.addEventListener("click", () => {
            navLinks.style.display = "flex";
            hamburger.style.display = "none";
            closeIcon.style.display = "block";
        });

        closeIcon.addEventListener("click", () => {
            navLinks.style.display = "none";
            closeIcon.style.display = "none";
            hamburger.style.display = "block";
        });
    </script>

</body>

</html>