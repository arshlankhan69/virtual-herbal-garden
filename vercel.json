{
  "version": 2,
  "builds": [
    {
      "src": "backend/app.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/public/(.*)", "dest": "/frontend/public/$1" },
    { "src": "/(.*)", "dest": "/backend/app.js" }
  ]
}